# ─── Firebase Realtime Database ────────────────────────────────────────────────
FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ─── Google Cloud Pub/Sub ──────────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
PUBSUB_TOPIC_ZONE_UPDATES=zone-updates
PUBSUB_TOPIC_ALERTS=alerts

# ─── Simulation Config ─────────────────────────────────────────────────────────
# Default event phase: PRE_GAME | HALF_TIME | POST_GAME | EMERGENCY
SIM_PHASE=PRE_GAME
# Tick interval in milliseconds (default: 3000 = 3 seconds)
SIM_TICK_MS=3000
# Speed multiplier: 1 | 2 | 5
SIM_SPEED=1
# Venue ID to simulate
SIM_VENUE_ID=ARENA_PRIME
