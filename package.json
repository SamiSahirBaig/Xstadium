{
  "name": "xstadium",
  "version": "1.0.0",
  "description": "Xstadium — AI-powered Sentient Stadium OS",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "simulator"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:simulator": "npm run dev --workspace=simulator",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install",
    "lint": "eslint . --ext .js,.jsx --ignore-path .gitignore",
    "lint:fix": "eslint . --ext .js,.jsx --fix --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\" --ignore-path .gitignore",
    "gcp:check": "node scripts/check-gcp.js",
    "gcp:setup-pubsub": "node scripts/setup-pubsub.js",
    "gcp:setup-bigquery": "node scripts/setup-bigquery.js",
    "gcp:setup-all": "npm run gcp:setup-pubsub && npm run gcp:setup-bigquery",
    "demo:reset": "node scripts/reset-demo.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
